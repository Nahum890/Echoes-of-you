  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::TutorialTrigger
  message: "Nivel 7 \u2014 El N\xFAcleo C\xEDclico"
  hint: "Esta es una sinfon\xEDa de tres ecos: 1. Un eco pisa la placa izquierda
    para subir el ascensor. 2. Otro eco sube por el ascensor y camina por la cornisa
    derecha para meterse dentro de la barrera roja. 3. Un tercer eco pisa la placa
    derecha para alinear el puente central. Corre a trav\xE9s del puente y cruza
    la barrera azul."
  displayDuration: 12
  oneShot: 1
  playerTag: Player
